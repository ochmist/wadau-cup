# Wadau Cup — Firebase environment variables
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from Firebase Console -> Project Settings -> Your apps -> Web app config.

# Firebase client SDK (exposed to browser — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=wadau-cup.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=wadau-cup
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=wadau-cup.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=953613944093
NEXT_PUBLIC_FIREBASE_APP_ID=1:953613944093:web:dc83f89e59f9354c0bcdf4

# Pool config
NEXT_PUBLIC_POOL_ID=default

# Local emulator project id. Keep this aligned with seeded emulator data.
NEXT_PUBLIC_FIREBASE_EMULATOR_PROJECT_ID=demo-wadau
FIREBASE_EMULATOR_PROJECT_ID=demo-wadau

# Firebase Admin SDK (server-only — never expose to browser)
# Option A: service account JSON pasted as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: individual fields (alternative to JSON above)
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Match data adapter (server-only)
# Primary source for full-time results and production scoring.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC

# Public fixture seed / fallback / optional cross-check.
OPENFOOTBALL_FIXTURES_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
REQUIRE_RESULT_CROSS_CHECK=true

# Optional in-game live score layer. Keep disabled until the API-Football key/quota is ready.
API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
ENABLE_LIVE_LAYER=false
LIVE_POLL_SECONDS=540
API_FOOTBALL_DAILY_CAP=90

# Protected sync endpoint / cron guard.
SYNC_CRON_SECRET=
FULL_TIME_POLL_SECONDS=75

# Production ops scripts
# Used by scripts/prod-bootstrap.mjs and scripts/setup-prod-cron.mjs.
PROD_BASE_URL=
CLOUD_SCHEDULER_LOCATION=us-central1
CLOUD_SCHEDULER_TIME_ZONE=America/New_York
