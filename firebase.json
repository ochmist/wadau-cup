{
  "apphosting": [
    {
      "backendId": "wadau-cup",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        ".next",
        ".env.local",
        ".env*.local",
        "serviceAccount*.json",
        "*.service-account.json",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "firestore-debug.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": false
  }
}
